---
import type { Locale } from '../i18n';
import { getContent, localePath } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getContent(locale);
const { footer: f, site, nav } = t;
const { contact } = site;
const year = new Date().getFullYear();
const baseUrl = import.meta.env.BASE_URL;
const homePath = localePath(locale, '', baseUrl);

const navLinks = [
  { href: '#services', label: nav.services.toUpperCase() },
  { href: '#works', label: nav.works.toUpperCase() },
  { href: '#methodology', label: nav.studio.toUpperCase() },
  { href: '#contact', label: nav.contact.toUpperCase() },
];
---

<footer class="site-footer">
  <div class="site-footer__utility container">
    <div class="site-footer__col site-footer__col--email">
      <p class="site-footer__label">{f.letsTalk}</p>
      <a class="site-footer__email" href={`mailto:${contact.email}`}>{contact.email}</a>
    </div>

    <nav class="site-footer__col site-footer__col--nav" aria-label={f.navAria}>
      <ul class="site-footer__nav">
        {navLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="site-footer__col site-footer__col--social">
      <ul class="site-footer__social">
        <li><a href={contact.linkedin} target="_blank" rel="noopener noreferrer" aria-label="Facebook">FB</a></li>
        <li><a href={contact.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram">IG</a></li>
        <li><a href={contact.whatsapp} target="_blank" rel="noopener noreferrer" aria-label="Discord">DC</a></li>
        <li><a href={contact.linkedin} target="_blank" rel="noopener noreferrer" aria-label="X">X</a></li>
        <li><a href={contact.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">IN</a></li>
      </ul>
    </div>

    <div class="site-footer__col site-footer__col--time">
      <p class="site-footer__label">{f.localTime}</p>
      <p class="site-footer__clock" data-footer-clock>{contact.timezone}</p>
    </div>
  </div>

  <div class="site-footer__wordmark container">
    <a href={homePath} aria-label={f.wordmarkLabel}>
      <img src={`${baseUrl}assets/brand/wordmark-footer.svg`} alt="" width="1280" height="166" decoding="async" />
    </a>
  </div>

  <div class="site-footer__bar container">
    <p class="site-footer__copy">© {year} | 2099.studio — {f.rights}</p>
    <button class="site-footer__top" type="button" data-back-to-top>
      <span>{f.backToTop}</span>
      <span aria-hidden="true">↑</span>
    </button>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    padding-top: 64px;
  }

  .site-footer__utility {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr auto;
    gap: var(--gap-layout);
    align-items: start;
    padding-bottom: 48px;
  }

  .site-footer__label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-text-tertiary);
    margin-bottom: 12px;
    text-transform: uppercase;
  }

  .site-footer__email {
    font-family: var(--font-display);
    font-size: var(--text-footer-email);
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-text-primary);
    word-break: break-word;
  }

  .site-footer__email:hover {
    color: var(--color-primary);
  }

  .site-footer__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    list-style: none;
  }

  .site-footer__nav a {
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
    text-transform: uppercase;
  }

  .site-footer__nav a:hover {
    color: var(--color-text-primary);
  }

  .site-footer__social {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    list-style: none;
  }

  .site-footer__social a {
    font-size: 11px;
    font-weight: 700;
    color: var(--color-text-secondary);
  }

  .site-footer__social a:hover {
    color: var(--color-primary);
  }

  .site-footer__col--time {
    text-align: right;
  }

  .site-footer__clock {
    font-size: 16px;
    font-weight: 500;
    color: var(--color-text-primary);
    font-variant-numeric: tabular-nums;
  }

  .site-footer__wordmark {
    line-height: 0;
    padding-block: 16px 8px;
  }

  .site-footer__wordmark img {
    display: block;
    width: 100%;
    height: auto;
    max-height: clamp(80px, 11.528vw, 221px);
    object-fit: contain;
    object-position: left center;
  }

  .site-footer__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 24px 0 40px;
    border-top: 1px solid var(--color-border);
  }

  .site-footer__copy {
    flex: 1;
    font-size: 11px;
    color: var(--color-text-tertiary);
  }

  .site-footer__top {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
  }

  .site-footer__top:hover {
    color: var(--color-text-primary);
    border-color: var(--color-primary);
  }

  @media (max-width: 900px) {
    .site-footer__utility {
      grid-template-columns: 1fr 1fr;
    }

    .site-footer__col--email {
      grid-column: 1 / -1;
    }

    .site-footer__col--time {
      text-align: left;
    }

    .site-footer__bar {
      flex-direction: column;
      align-items: stretch;
    }

    .site-footer__top {
      justify-content: center;
    }
  }
</style>

<script>
  document.querySelector('[data-back-to-top]')?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  const clock = document.querySelector('[data-footer-clock]');
  if (clock) {
    const tick = () => {
      clock.textContent = new Intl.DateTimeFormat(undefined, {
        hour: 'numeric',
        minute: '2-digit',
        timeZone: 'America/Argentina/Buenos_Aires',
      }).format(new Date());
    };
    tick();
    setInterval(tick, 30000);
  }
</script>
