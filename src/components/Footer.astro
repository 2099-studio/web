---
import type { Locale } from '../i18n';
import { getContent, localePath } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getContent(locale);
const { footer: f, site, nav } = t;
const { contact } = site;
const year = new Date().getFullYear();
const baseUrl = import.meta.env.BASE_URL;
const homePath = localePath(locale, '', baseUrl);

const navLinks = [
  { href: '#services', label: nav.services.toUpperCase() },
  { href: '#works', label: nav.works.toUpperCase() },
  { href: '#methodology', label: nav.studio.toUpperCase() },
  { href: '#contact', label: nav.contact.toUpperCase() },
];

const socialLinks = [
  {
    label: 'Facebook',
    href: contact.linkedin,
    icon: 'M12 2.04c-5.5 0-10 4.49-10 10.02 0 5 3.66 9.15 8.44 9.9v-7H7.9v-2.9h2.54V9.85c0-2.52 1.49-3.93 3.78-3.93 1.09 0 2.24.2 2.24.2v2.47h-1.26c-1.24 0-1.63.78-1.63 1.57v1.88h2.78l-.45 2.9h-2.33v7a10 10 0 0 0 8.44-9.9c0-5.53-4.5-10.02-10-10.02Z',
  },
  {
    label: 'Instagram',
    href: contact.instagram,
    icon: 'M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5Zm10 2H7a3 3 0 0 0-3 3v10a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3V7a3 3 0 0 0-3-3Zm-5 3.5A4.5 4.5 0 1 1 7.5 12 4.5 4.5 0 0 1 12 7.5Zm0 2A2.5 2.5 0 1 0 14.5 12 2.5 2.5 0 0 0 12 9.5ZM17.75 6.5a1 1 0 1 1-1 1 1 1 0 0 1 1-1Z',
  },
  {
    label: 'Discord',
    href: contact.whatsapp,
    icon: 'M19.27 5.33A16.3 16.3 0 0 0 14.91 4l-.23.45a14.3 14.3 0 0 1 3.48 1.67 11.5 11.5 0 0 0-10.32 0A14.3 14.3 0 0 1 11.3 4l-.22-.45a16.3 16.3 0 0 0-4.37 1.33C2.68 9.88 1.9 14.3 2.3 18.66a16.6 16.6 0 0 0 5.02 2.54l.64-.98a10.8 10.8 0 0 1-1.61-.77l.4-.31a11.8 11.8 0 0 0 10.5 0l.4.31a10.8 10.8 0 0 1-1.61.77l.64.98a16.6 16.6 0 0 0 5.02-2.54c.48-5.05-.81-9.42-2.63-13.33ZM9.3 15.55c-.84 0-1.53-.78-1.53-1.73s.67-1.73 1.53-1.73 1.55.78 1.53 1.73-.68 1.73-1.53 1.73Zm5.4 0c-.84 0-1.53-.78-1.53-1.73s.67-1.73 1.53-1.73 1.54.78 1.53 1.73-.68 1.73-1.53 1.73Z',
  },
  {
    label: 'X',
    href: contact.linkedin,
    icon: 'M17.3 3H20.5l-7.19 8.22L21.5 21h-5.9l-4.62-6.04L5.9 21H2.66l7.69-8.79L2.5 3h6.05l4.17 5.52L17.3 3Zm-1.04 16.2h1.67L7.84 4.7H6.05l10.21 14.5Z',
  },
  {
    label: 'LinkedIn',
    href: contact.linkedin,
    icon: 'M6.94 6.5A2.19 2.19 0 1 1 4.75 4.3 2.19 2.19 0 0 1 6.94 6.5ZM4.9 8.77h4.08V21H4.9Zm7.12 0h3.91v1.67h.06a4.29 4.29 0 0 1 3.86-2.12c4.13 0 4.89 2.72 4.89 6.25V21h-4.08v-5.6c0-1.34 0-3.06-1.87-3.06s-2.15 1.46-2.15 3V21h-4.08Z',
  },
];
---

<footer class="site-footer">
  <div class="site-footer__utility container">
    <div class="site-footer__col site-footer__col--email">
      <p class="site-footer__label">{f.letsTalk}</p>
      <a class="site-footer__email" href={`mailto:${contact.email}`}>{contact.email}</a>
    </div>

    <nav class="site-footer__col site-footer__col--nav" aria-label={f.navAria}>
      <ul class="site-footer__nav">
        {navLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="site-footer__col site-footer__col--social">
      <ul class="site-footer__social">
        {socialLinks.map((link) => (
          <li>
            <a href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.label}>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d={link.icon}></path>
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="site-footer__col site-footer__col--time">
      <p class="site-footer__label">{f.localTime}</p>
      <p class="site-footer__clock" data-footer-clock>{contact.timezone}</p>
    </div>
  </div>

  <div class="site-footer__wordmark container">
    <a href={homePath} aria-label={f.wordmarkLabel}>
      <img src={`${baseUrl}assets/brand/wordmark-footer.svg`} alt="" width="1280" height="166" decoding="async" />
    </a>
  </div>

  <div class="site-footer__bar container">
    <p class="site-footer__copy">© {year} | 2099.studio — {f.rights}</p>
    <button class="site-footer__top" type="button" data-back-to-top>
      <span>{f.backToTop}</span>
      <span aria-hidden="true">↑</span>
    </button>
  </div>
</footer>

<style>
  .site-footer {
    background: transparent;
    border-top: 1px solid var(--color-border);
    padding-top: 64px;
  }

  .site-footer__utility {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr auto;
    gap: var(--gap-layout);
    align-items: start;
    padding-bottom: 48px;
  }

  .site-footer__label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-text-tertiary);
    margin-bottom: 12px;
    text-transform: uppercase;
  }

  .site-footer__email {
    font-family: var(--font-display);
    font-size: var(--text-footer-email);
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-text-primary);
    word-break: break-word;
  }

  .site-footer__email:hover {
    color: var(--color-primary);
  }

  .site-footer__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-footer__nav a {
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
    text-transform: uppercase;
  }

  .site-footer__nav a:hover {
    color: var(--color-text-primary);
  }

  .site-footer__social {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 24px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-footer__social a {
    display: inline-flex;
    color: var(--color-text-secondary);
    transition: color 0.2s ease;
  }

  .site-footer__social a:hover {
    color: var(--color-primary);
  }

  .site-footer__col--time {
    text-align: right;
  }

  .site-footer__clock {
    font-size: 16px;
    font-weight: 500;
    color: var(--color-text-primary);
    font-variant-numeric: tabular-nums;
  }

  .site-footer__wordmark {
    line-height: 0;
    padding-block: 16px 8px;
  }

  .site-footer__wordmark img {
    display: block;
    width: 100%;
    height: auto;
    max-height: clamp(80px, 11.528vw, 166px);
    object-fit: contain;
    object-position: left center;
  }

  .site-footer__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 24px 0 40px;
    border-top: 1px solid var(--color-border);
  }

  .site-footer__copy {
    flex: 1;
    font-size: 11px;
    color: var(--color-text-tertiary);
  }

  .site-footer__top {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    background: transparent;
    cursor: pointer;
  }

  .site-footer__top:hover {
    color: var(--color-text-primary);
    border-color: var(--color-primary);
  }

  @media (max-width: 900px) {
    .site-footer__utility {
      grid-template-columns: 1fr 1fr;
    }

    .site-footer__col--email {
      grid-column: 1 / -1;
    }

    .site-footer__col--time {
      text-align: left;
    }

    .site-footer__bar {
      flex-direction: column;
      align-items: stretch;
    }

    .site-footer__top {
      justify-content: center;
    }
  }
</style>

<script>
  document.querySelector('[data-back-to-top]')?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  const clock = document.querySelector('[data-footer-clock]');
  if (clock) {
    const tick = () => {
      clock.textContent = new Intl.DateTimeFormat(undefined, {
        hour: 'numeric',
        minute: '2-digit',
        timeZone: 'America/Argentina/Buenos_Aires',
      }).format(new Date());
    };
    tick();
    setInterval(tick, 30000);
  }
</script>
