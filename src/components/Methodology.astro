---
import type { Locale } from '../i18n';
import { getContent } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getContent(locale);
const { methodology } = t;
---

<section class="methodology figma-section" id="methodology" data-methodology aria-labelledby="methodology-title">
  <div class="methodology__wrap container">
    <div class="methodology__inner">
      <aside class="methodology__sidebar">
        <div class="methodology__intro">
          <span class="figma-badge">{methodology.badge}</span>
          <h2 class="methodology__title" id="methodology-title">
            {methodology.title}{' '}
            <span class="methodology__title-accent">{methodology.titleHighlight}</span>.
          </h2>
          <p class="methodology__lead">{methodology.lead}</p>
        </div>
        <div class="methodology__rail" aria-hidden="true">
          <div class="methodology__rail-track">
            <div class="methodology__rail-fill" data-methodology-progress></div>
          </div>
        </div>
      </aside>

      <ol class="methodology__steps">
        {
          methodology.steps.map((step, index) => (
            <li class={`methodology__step${index === 0 ? ' is-active' : ''}`} data-methodology-step data-step-index={index}>
              <article class="methodology__card">
                <div class="methodology__card-top">
                  <span class="methodology__dot" aria-hidden="true"></span>
                  <div class="methodology__meta">
                    <span class="methodology__num">{step.number}</span>
                    <h3 class="methodology__name">{step.title}</h3>
                  </div>
                </div>
                <div class="methodology__card-body">
                  <p class="methodology__desc">{step.description}</p>
                  <div class="methodology__tools-block">
                    <span class="methodology__tools-label">{methodology.toolsLabel}</span>
                    <ul class="methodology__tools" aria-label={methodology.toolsLabel}>
                      {step.tools.map((tool) => (
                        <li class="methodology__tool">{tool}</li>
                      ))}
                    </ul>
                  </div>
                </div>
              </article>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>

<style>
  .methodology__inner {
    display: grid;
    grid-template-columns: minmax(0, var(--sidebar-methodology)) minmax(0, 1fr);
    gap: clamp(32px, 4.444vw, 64px);
    align-items: start;
  }

  .methodology__sidebar {
    position: sticky;
    top: calc(var(--header-height) + 32px);
    display: flex;
    flex-direction: column;
    gap: clamp(24px, 2.222vw, 32px);
  }

  .methodology__intro {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: clamp(16px, 1.667vw, 24px);
  }

  .methodology__title {
    font-family: var(--font-display);
    font-size: var(--text-section-title);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    margin: 0;
    text-wrap: balance;
  }

  .methodology__title-accent {
    color: var(--color-primary);
  }

  .methodology__lead {
    margin: 0;
    max-width: min(340px, 100%);
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-weight: 400;
    line-height: 1.55;
    color: var(--color-text-secondary);
    text-wrap: pretty;
  }

  .methodology__rail-track {
    width: 2px;
    height: clamp(140px, 13.889vw, 200px);
    background: var(--color-border);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .methodology__rail-fill {
    width: 100%;
    height: 100%;
    background: var(--color-primary);
    transform-origin: top;
    transform: scaleY(0.2);
    transition: transform 0.35s ease;
  }

  .methodology__steps {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: clamp(12px, 1.111vw, 16px);
    min-width: 0;
  }

  .methodology__step {
    min-width: 0;
  }

  .methodology__card {
    display: flex;
    flex-direction: column;
    gap: clamp(12px, 1.111vw, 16px);
    min-height: var(--methodology-card-min);
    padding: clamp(18px, 1.667vw, 24px) clamp(20px, 2.222vw, 32px);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    background: var(--color-surface);
    transition:
      opacity 0.35s ease,
      background 0.35s ease,
      border-color 0.35s ease,
      padding 0.35s ease,
      gap 0.35s ease;
  }

  .methodology__step.is-active .methodology__card {
    gap: clamp(16px, 1.389vw, 20px);
    padding: clamp(24px, 2.222vw, 32px);
    background: var(--color-elevated);
    border-color: color-mix(in srgb, var(--color-primary) 42%, var(--color-border));
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-primary) 12%, transparent);
    opacity: 1;
  }

  .methodology__step:not(.is-active) .methodology__card {
    opacity: 0.52;
  }

  .methodology__card-top {
    display: flex;
    align-items: flex-start;
    gap: clamp(12px, 1.111vw, 16px);
    min-width: 0;
  }

  .methodology__dot {
    flex-shrink: 0;
    width: 12px;
    height: 12px;
    margin-top: 0.55em;
    border-radius: 50%;
    border: 2px solid var(--color-border);
    background: var(--color-bg);
    transition: border-color 0.35s ease, background 0.35s ease, transform 0.35s ease;
  }

  .methodology__step.is-active .methodology__dot {
    border-color: var(--color-primary);
    background: var(--color-primary);
    transform: scale(1.08);
  }

  .methodology__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 10px clamp(12px, 1.111vw, 16px);
    min-width: 0;
  }

  .methodology__num {
    flex-shrink: 0;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.06em;
    color: var(--color-text-tertiary);
    transition: color 0.35s ease;
  }

  .methodology__step.is-active .methodology__num {
    color: var(--color-primary);
  }

  .methodology__name {
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 1.667vw, var(--text-methodology-step));
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -0.015em;
    color: var(--color-text-primary);
    text-wrap: balance;
  }

  .methodology__card-body {
    display: flex;
    flex-direction: column;
    gap: clamp(14px, 1.25vw, 18px);
    padding-left: calc(12px + clamp(12px, 1.111vw, 16px));
    min-width: 0;
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition:
      max-height 0.45s ease,
      opacity 0.35s ease,
      padding 0.35s ease;
  }

  .methodology__step.is-active .methodology__card-body {
    max-height: 480px;
    opacity: 1;
  }

  .methodology__desc {
    margin: 0;
    font-family: var(--font-body);
    font-size: clamp(15px, 1.111vw, 16px);
    line-height: 1.6;
    color: var(--color-text-secondary);
    text-wrap: pretty;
    overflow-wrap: anywhere;
  }

  .methodology__tools-block {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .methodology__tools-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
  }

  .methodology__step.is-active .methodology__tools-label {
    color: color-mix(in srgb, var(--color-primary) 70%, var(--color-text-tertiary));
  }

  .methodology__tools {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
  }

  .methodology__tool {
    padding: 5px 12px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    line-height: 1.2;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    white-space: nowrap;
    transition: color 0.35s ease, border-color 0.35s ease, background 0.35s ease;
  }

  .methodology__step.is-active .methodology__tool {
    color: var(--color-primary);
    border-color: color-mix(in srgb, var(--color-primary) 38%, var(--color-border));
    background: color-mix(in srgb, var(--color-primary) 6%, transparent);
  }

  @media (min-width: 1024px) {
    .methodology__step:not(.is-active) .methodology__card-body {
      max-height: 0;
      opacity: 0;
      padding-top: 0;
      padding-bottom: 0;
    }
  }

  @media (max-width: 1023px) {
    .methodology__inner {
      grid-template-columns: 1fr;
      gap: clamp(32px, 5vw, 48px);
    }

    .methodology__sidebar {
      position: static;
    }

    .methodology__lead {
      max-width: min(640px, 100%);
    }

    .methodology__step:not(.is-active) .methodology__card {
      opacity: 0.72;
    }

    .methodology__card-body {
      max-height: none;
      opacity: 1;
      overflow: visible;
    }

    .methodology__card {
      gap: clamp(14px, 1.389vw, 18px);
      padding: clamp(20px, 2.5vw, 28px);
    }
  }

  @media (max-width: 767px) {
    .methodology__card-body {
      padding-left: 0;
    }

    .methodology__card-top {
      align-items: center;
    }

    .methodology__dot {
      margin-top: 0;
    }

    .methodology__tool {
      white-space: normal;
      text-align: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .methodology__card,
    .methodology__card-body,
    .methodology__dot,
    .methodology__rail-fill {
      transition: none;
    }

    .methodology__card-body {
      max-height: none;
      opacity: 1;
      overflow: visible;
    }
  }
</style>
