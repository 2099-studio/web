---
import type { Locale } from '../i18n';
import { getContent } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getContent(locale);
const { methodology } = t;
---

<section class="methodology figma-section" id="methodology" data-methodology aria-labelledby="methodology-title">
  <div class="methodology__wrap container">
    <div class="methodology__inner">
      <aside class="methodology__sidebar">
        <div class="methodology__intro" data-reveal>
          <span class="figma-badge">{methodology.badge}</span>
          <h2 class="methodology__title" id="methodology-title" data-text-reveal>
            {methodology.title}
            {methodology.titleHighlight ? (
              <>
                {' '}
                <span class="methodology__title-accent">{methodology.titleHighlight}</span>.
              </>
            ) : null}
          </h2>
          {methodology.lead ? <p class="methodology__lead">{methodology.lead}</p> : null}
        </div>
        <div class="methodology__rail" aria-hidden="true">
          <div class="methodology__rail-track">
            <div class="methodology__rail-fill" data-methodology-progress></div>
          </div>
        </div>
      </aside>

      <ol class="methodology__steps">
        {
          methodology.steps.map((step, index) => (
            <li class={`methodology__step${index === 0 ? ' is-active' : ''}`} data-methodology-step data-step-index={index}>
              <article class="methodology__card">
                <span class="methodology__dot" aria-hidden="true"></span>
                <div class="methodology__content">
                  <div class="methodology__meta">
                    <span class="methodology__num">{step.number}</span>
                    <h3 class="methodology__name">{step.title}</h3>
                  </div>
                  <p class="methodology__desc">{step.description}</p>
                </div>
              </article>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>

<style>
  .methodology__inner {
    display: grid;
    grid-template-columns: minmax(0, var(--sidebar-methodology)) minmax(0, 1fr);
    gap: clamp(32px, 4.444vw, 64px);
    align-items: start;
  }

  .methodology__sidebar {
    position: sticky;
    top: calc(var(--header-height) + 32px);
    display: flex;
    flex-direction: column;
    gap: clamp(24px, 2.222vw, 32px);
  }

  .methodology__intro {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: clamp(16px, 1.667vw, 24px);
  }

  .methodology__title {
    font-family: var(--font-display);
    font-size: var(--text-section-title-lg);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.96px;
    color: var(--color-text-primary);
    margin: 0;
    max-width: 12ch;
    text-wrap: balance;
  }

  .methodology__title-accent {
    color: var(--color-primary);
  }

  .methodology__lead {
    margin: 0;
    max-width: min(340px, 100%);
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-weight: 400;
    line-height: 1.55;
    color: var(--color-text-secondary);
    text-wrap: pretty;
  }

  .methodology__rail-track {
    width: 2px;
    height: clamp(140px, 13.889vw, 200px);
    background: var(--color-border);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .methodology__rail-fill {
    width: 100%;
    height: 100%;
    background: var(--color-primary);
    transform-origin: top;
    transform: scaleY(0.2);
    transition: transform 0.35s ease;
  }

  .methodology__steps {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 24px;
    min-width: 0;
    margin: 0;
    padding: 0;
  }

  .methodology__step {
    min-width: 0;
  }

  /* Figma 608:339 — row: dot + content column; all cards 160 min */
  .methodology__card {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 24px;
    min-height: var(--methodology-card-min);
    padding: var(--methodology-card-pad);
    border: 1px solid var(--color-border);
    border-radius: var(--methodology-card-radius);
    background: var(--color-surface);
    transition:
      opacity 0.35s ease,
      background 0.35s ease,
      border-color 0.35s ease;
  }

  .methodology__step.is-active .methodology__card {
    background: var(--color-elevated);
    border-color: var(--color-border);
    opacity: 1;
  }

  .methodology__step:not(.is-active) .methodology__card {
    opacity: 0.45;
  }

  .methodology__dot {
    flex-shrink: 0;
    width: 12px;
    height: 12px;
    margin-top: 6px;
    border-radius: 50%;
    border: 2px solid var(--color-border);
    background: transparent;
    transition:
      border-color 0.35s ease,
      background 0.35s ease;
  }

  .methodology__step.is-active .methodology__dot {
    border-color: var(--color-primary);
    background: var(--color-primary);
  }

  .methodology__content {
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-width: 0;
    flex: 1;
  }

  .methodology__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 16px;
    min-width: 0;
  }

  .methodology__num {
    flex-shrink: 0;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0;
    color: var(--color-text-tertiary);
    transition: color 0.35s ease;
  }

  .methodology__step.is-active .methodology__num {
    color: var(--color-primary);
  }

  .methodology__name {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-methodology-step);
    font-weight: 700;
    line-height: normal;
    letter-spacing: 0;
    color: var(--color-text-primary);
    text-wrap: balance;
  }

  .methodology__desc {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-methodology-desc);
    font-weight: 400;
    line-height: 1.35;
    color: var(--color-text-secondary);
    text-wrap: pretty;
    overflow-wrap: anywhere;
  }

  @media (max-width: 1023px) {
    .methodology__inner {
      grid-template-columns: 1fr;
      gap: clamp(32px, 5vw, 48px);
    }

    .methodology__sidebar {
      position: static;
    }

    .methodology__title {
      max-width: 20ch;
    }

    .methodology__lead {
      max-width: min(640px, 100%);
    }

    .methodology__step:not(.is-active) .methodology__card {
      opacity: 0.72;
    }

    .methodology__card {
      gap: 16px;
      padding: clamp(20px, 2.5vw, 28px);
    }
  }

  @media (max-height: 900px) {
    .methodology.figma-section {
      min-height: 0;
      padding-block: var(--section-padding-y);
    }

    .methodology__steps {
      gap: clamp(12px, 1.8vh, 20px);
    }

    .methodology__card {
      min-height: var(--methodology-card-min);
      padding: var(--methodology-card-pad);
      gap: 16px;
    }

    .methodology__title {
      font-size: clamp(1.5rem, 3.5vh, var(--text-section-title-lg));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .methodology__card,
    .methodology__dot,
    .methodology__rail-fill {
      transition: none;
    }
  }
</style>
