---
import type { Locale } from '../i18n';
import { getContent } from '../i18n';
import IndustryPanel from './IndustryPanel.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getContent(locale);
const { industries } = t;
---

<section class="industries figma-section" id="industries" data-industries aria-labelledby="industries-title">
  <div class="industries__wrap container container--wide">
    <header class="figma-section__head industries__head" data-reveal>
      <span class="figma-badge industries__badge">{industries.badge}</span>
      <h2 class="figma-section__title industries__title" id="industries-title">
        {industries.title}<br />{industries.titleLine2}
      </h2>
    </header>

    <div class="industries__body industries__body--desktop">
      <div class="industries__tabs" role="tablist" aria-label={industries.badge}>
        {
          industries.layers.map((layer, index) => (
            <button
              type="button"
              class={`industries__tab${index === 0 ? ' is-active' : ''}`}
              role="tab"
              aria-selected={index === 0}
              data-industry-tab
              data-tab-index={index}
            >
              {layer.tabLabel}
            </button>
          ))
        }
      </div>

      <div class="industries__panel-wrap">
        {
          industries.layers.map((layer, index) => (
            <IndustryPanel
              index={index}
              folderTab={layer.folderTab}
              panelTitle={layer.panelTitle}
              badge={layer.badge}
              sectorsLabel={industries.sectors}
              servicesLabel={industries.typicalServices}
              sectors={layer.sectors}
              services={layer.services}
              hidden={index !== 0}
            />
          ))
        }
      </div>
    </div>

    <div class="industries__body industries__body--mobile">
      <div class="industries__mobile-track" data-industry-mobile-track>
        {
          industries.layers.map((layer, index) => (
            <article class="industries__mobile-slide" data-industry-mobile-slide>
              <div class="industries__tab industries__tab--chip is-active">{layer.tabLabel}</div>
              <IndustryPanel
                index={index}
                folderTab={layer.folderTab}
                panelTitle={layer.panelTitle}
                badge={layer.badge}
                sectorsLabel={industries.sectors}
                servicesLabel={industries.typicalServices}
                sectors={layer.sectors}
                services={layer.services}
                isMobile={true}
              />
            </article>
          ))
        }
      </div>

      <div class="industries__mobile-nav">
        <button type="button" class="industry-panel__arrow" data-industry-mobile-prev aria-label="Anterior">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M14.378 8H1.802M1.802 8L8.09 1.712M1.802 8L8.09 14.288" stroke="currentColor" stroke-width="1.5"></path>
          </svg>
        </button>
        <div class="industries__pager" data-industry-dots>
          {industries.layers.map((_, index) => (
            <button
              type="button"
              class={`industries__pager-dot${index === 0 ? ' is-active' : ''}`}
              data-industry-dot={index}
              aria-label={`Capa ${index + 1}`}
            ></button>
          ))}
        </div>
        <button type="button" class="industry-panel__arrow" data-industry-mobile-next aria-label="Siguiente">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M2.704 8H14.023M14.023 8L8.363 13.659M14.023 8L8.363 2.341" stroke="currentColor" stroke-width="1.5"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* Figma 587:2910 — frame 1440, tabs 300 + gap 20 + panel 961×452 */
  .industries {
    --ind-tab-w: clamp(260px, 20.833vw, 300px);
    --ind-gap: 20px;
    --ind-tab-gap: 12px;
    --ind-panel-ratio: 961 / 452;
  }

  .industries__head.figma-section__head {
    margin-bottom: clamp(32px, 4.444vw, 64px);
  }

  .industries__title.figma-section__title {
    font-size: clamp(1.75rem, 3.333vw, 48px);
    letter-spacing: -0.02em;
  }

  .industries__body--mobile {
    display: none;
  }

  .industries__body--desktop {
    display: grid;
    grid-template-columns: var(--ind-tab-w) minmax(0, 1fr);
    gap: var(--ind-gap);
    align-items: stretch;
  }

  .industries__tabs {
    display: flex;
    flex-direction: column;
    gap: var(--ind-tab-gap);
    min-height: 100%;
  }

  .industries__tab {
    display: flex;
    align-items: center;
    flex: 1 1 0;
    min-height: clamp(88px, 7.36vw, 106px);
    min-width: 0;
    padding: 20px;
    font-family: var(--font-body);
    font-size: clamp(1.125rem, 2.222vw, 32px);
    font-weight: 500;
    line-height: 1.2;
    color: var(--color-industry-tab-text);
    text-align: left;
    background: var(--color-industry-tab-bg);
    border: 1px solid var(--color-industry-tab-border);
    border-radius: 16px;
    cursor: pointer;
    overflow-wrap: break-word;
    hyphens: auto;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .industries__tab:hover:not(.is-active) {
    border-color: color-mix(in srgb, var(--color-primary) 30%, var(--color-industry-tab-border));
  }

  .industries__tab.is-active {
    background: var(--color-primary);
    border-color: var(--color-industry-tab-border);
    color: var(--color-industry-tab-active-text);
  }

  .industries__panel-wrap {
    position: relative;
    aspect-ratio: var(--ind-panel-ratio);
    width: 100%;
    max-width: 961px;
    min-width: 0;
    justify-self: end;
  }

  .industries__panel-wrap .industry-panel {
    position: absolute;
    inset: 0;
  }

  .industry-panel[hidden] {
    display: none;
  }

  .industry-panel.is-entering {
    animation: industries-panel-in 0.28s ease forwards;
  }

  @keyframes industries-panel-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .industry-panel__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    border: 1px solid var(--color-industry-panel-stroke);
    border-radius: 50%;
    background: var(--color-industry-control-bg);
    color: var(--color-industry-control-text);
    cursor: pointer;
    transition: border-color 0.2s, opacity 0.2s;
  }

  .industry-panel__arrow:hover:not(:disabled) {
    border-color: var(--color-primary);
  }

  .industry-panel__arrow:disabled,
  .industry-panel__arrow.is-inactive {
    opacity: 0.35;
    pointer-events: none;
  }

  @media (max-width: 767px) {
    .industries__body--desktop {
      display: none;
    }

    .industries__body--mobile {
      display: block;
    }

    .industries__mobile-track {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      gap: 16px;
      -ms-overflow-style: none;
      scrollbar-width: none;
    }

    .industries__mobile-track::-webkit-scrollbar {
      display: none;
    }

    .industries__mobile-slide {
      flex: 0 0 100%;
      scroll-snap-align: start;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .industries__tab--chip {
      flex: none;
      min-height: auto;
      width: fit-content;
      max-width: 100%;
      padding: 14px 18px;
      font-size: 18px;
      pointer-events: none;
    }

    .industries__panel-wrap {
      max-width: none;
      justify-self: stretch;
    }

    .industries__mobile-nav {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      margin-top: 20px;
    }

    .industries__pager {
      display: flex;
      flex: 1;
      gap: 6px;
      max-width: 200px;
    }

    .industries__pager-dot {
      flex: 1;
      height: 4px;
      padding: 0;
      border: none;
      border-radius: 8px;
      background: var(--color-border);
      cursor: pointer;
    }

    .industries__pager-dot.is-active {
      background: var(--color-text-primary);
    }
  }
</style>
