---
import type { Locale } from '../i18n';
import { getContent } from '../i18n';
import CanvasText from './CanvasText.astro';
import SparklesText from './SparklesText.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getContent(locale);
const baseUrl = import.meta.env.BASE_URL;
const slides = Array.from({ length: 5 }, (_, i) => {
  const n = String(i + 1).padStart(2, '0');
  return `${baseUrl}assets/brand/hero-slides/${n}.jpg`;
});

const highlight = t.hero.titleHighlight?.trim() || '';
const titleLines = t.hero.title.split('\n').map((line) => line.trim()).filter(Boolean);

const leadLines = [t.hero.lead, t.hero.leadSecondary].filter(
  (line): line is string => Boolean(line?.trim()),
);

function splitHighlight(line: string) {
  if (!highlight) return { before: line, match: '', after: '' };
  const index = line.lastIndexOf(highlight);
  if (index < 0) return { before: line, match: '', after: '' };
  return {
    before: line.slice(0, index),
    match: highlight,
    after: line.slice(index + highlight.length),
  };
}
---

<section class="hero" id="hero" aria-labelledby="hero-title" data-hero>
  <div class="hero__inner container">
    <p class="hero__eyebrow" data-hero-content>{t.hero.eyebrow}</p>

    <div class="hero__copy" data-hero-title>
      <h1 class="hero__title" id="hero-title">
        {
          titleLines.map((line) => {
            const { before, match, after } = splitHighlight(line);
            return (
              <span class="hero__title-line">
                {before}
                {match ? (
                  <SparklesText class="hero__title-sparkles">
                    <CanvasText text={match} class="hero__title-canvas" />
                  </SparklesText>
                ) : null}
                {after}
              </span>
            );
          })
        }
      </h1>
      <p class="hero__lead" data-hero-content>
        {leadLines.map((line) => (
          <span class="hero__lead-line">{line}</span>
        ))}
      </p>
    </div>

    <div class="hero__actions" data-hero-content>
      <a class="btn-figma-primary" href="#contact">{t.hero.ctaWorks}</a>
      <a class="btn-figma-secondary" href="#investment">{t.hero.ctaContact}</a>
    </div>
  </div>

  <div class="hero__carousel" data-hero-carousel data-reveal aria-roledescription="carousel">
    <div class="hero__viewport">
      <div class="hero__track" data-carousel-track>
        {
          slides.map((src, index) => (
            <article
              class={`hero__slide${index === 0 ? ' is-active' : ''}`}
              data-carousel-slide
              data-index={index}
              aria-hidden={index !== 0}
            >
              <img src={src} alt="" width="940" height="400" decoding="async" loading={index === 0 ? 'eager' : 'lazy'} />
            </article>
          ))
        }
      </div>
    </div>

    <div class="hero__nav" data-carousel-nav>
      <button type="button" class="hero__arrow" data-carousel-prev aria-label={locale === 'es' ? 'Anterior' : 'Previous'}>
        ←
      </button>
      <div class="hero__dots visually-hidden" role="tablist">
        {
          slides.map((_, index) => (
            <button
              type="button"
              class={`hero__dot${index === 0 ? ' is-active' : ''}`}
              data-carousel-dot={index}
              aria-label={`Slide ${index + 1}`}
            />
          ))
        }
      </div>
      <button type="button" class="hero__arrow" data-carousel-next aria-label={locale === 'es' ? 'Siguiente' : 'Next'}>
        →
      </button>
    </div>
  </div>
</section>

<style>
  /* Figma 608:218 — Title/Subtitle/CTA 812×308 + Slides Box 1440×400 */
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    justify-content: flex-start;
    gap: 36px;
    min-height: 100svh;
    padding-top: calc(var(--header-height) + 26px);
    padding-bottom: 24px;
    overflow-x: clip;
    overflow-y: visible;
    background: transparent;
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: min(100% - var(--margin) * 2, var(--hero-copy-max));
    margin-inline: auto;
    gap: 0;
    flex: 1 1 auto;
    justify-content: center;
  }

  .hero__eyebrow {
    margin: 0 0 14px;
    padding: 8px 16px;
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0;
    line-height: normal;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .hero__copy {
    width: 100%;
  }

  .hero__title {
    margin: 0 auto 16px;
    width: fit-content;
    max-width: 100%;
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: 0;
    color: var(--color-text-primary);
    white-space: normal;
    text-wrap: unset;
  }

  .hero__title-line {
    display: block;
    white-space: nowrap;
  }

  .hero__title :global(.sparkles-text),
  .hero__title :global(.canvas-text) {
    vertical-align: baseline;
  }

  .hero__title :global(.canvas-text__label) {
    font-weight: inherit;
  }

  .hero__lead {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    margin: 0 auto 16px;
    max-width: min(100%, var(--hero-copy-max));
    font-family: var(--font-body);
    font-size: var(--text-hero-lead);
    font-weight: 400;
    line-height: 1.7;
    letter-spacing: 0;
    color: #d9d9d9;
  }

  .hero__lead-line {
    display: block;
    white-space: nowrap;
  }

  :global([data-theme='light']) .hero__lead {
    color: var(--color-text-secondary);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 16px;
    /* Spacing to full-bleed strip comes from hero flex + carousel margin-top */
    margin-bottom: 0;
  }

  .hero__actions :global(.btn-figma-primary),
  .hero__actions :global(.btn-figma-secondary) {
    min-width: 91px;
    padding: var(--hero-btn-py) var(--hero-btn-px);
    font-family: var(--font-body);
    font-size: var(--text-hero-btn);
    font-weight: 500;
    letter-spacing: 0;
    text-transform: none;
    line-height: normal;
  }

  /* Full-bleed coverflow — peeks reach viewport edges (Figma Slides Box 1440) */
  .hero__carousel {
    position: relative;
    flex: 0 0 auto;
    width: 100vw;
    max-width: none;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
  }

  .hero__viewport {
    position: relative;
    overflow: hidden;
    width: 100%;
    height: var(--hero-slide-h);
    margin-inline: 0;
  }

  .hero__track {
    position: relative;
    height: 100%;
    width: 100%;
  }

  .hero__slide {
    position: absolute;
    top: 50%;
    left: 50%;
    width: var(--hero-far-w);
    height: var(--hero-far-h);
    border-radius: var(--hero-slide-radius);
    overflow: hidden;
    transform: translate(-50%, -50%);
    opacity: 0;
    visibility: hidden;
    z-index: 1;
    pointer-events: none;
    /* Only transform/opacity — animating width+translate(%) drifts slides off-center */
    transition:
      transform 0.7s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.5s ease,
      visibility 0.5s;
    will-change: transform, opacity;
  }

  .hero__slide img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero__slide.is-active {
    width: var(--hero-slide-w);
    height: var(--hero-slide-h);
    opacity: 1;
    visibility: visible;
    z-index: 5;
    pointer-events: auto;
    transform: translate(-50%, -50%);
  }

  .hero__slide.is-prev {
    width: var(--hero-near-w);
    height: var(--hero-near-h);
    opacity: 1;
    visibility: visible;
    z-index: 4;
    transform: translate(calc(-50% - var(--hero-near-x-prev)), -50%);
  }

  .hero__slide.is-next {
    width: var(--hero-near-w);
    height: var(--hero-near-h);
    opacity: 1;
    visibility: visible;
    z-index: 4;
    transform: translate(calc(-50% + var(--hero-near-x-next)), -50%);
  }

  .hero__slide.is-far-prev {
    width: var(--hero-far-w);
    height: var(--hero-far-h);
    opacity: 1;
    visibility: visible;
    z-index: 2;
    transform: translate(calc(-50% - var(--hero-far-x-prev)), -50%);
  }

  .hero__slide.is-far-next {
    width: var(--hero-far-w);
    height: var(--hero-far-h);
    opacity: 1;
    visibility: visible;
    z-index: 2;
    transform: translate(calc(-50% + var(--hero-far-x-next)), -50%);
  }

  /* Figma has no visible pagination under the strip — keep for a11y */
  .hero__nav {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 1023px) {
    .hero__slide.is-far-prev,
    .hero__slide.is-far-next {
      opacity: 0;
      visibility: hidden;
    }

    /* Allow title/lead to wrap — desktop nowrap clips on narrow widths */
    .hero__title {
      width: 100%;
      max-width: none;
      line-height: 1.05;
    }

    .hero__title-line,
    .hero__lead-line {
      white-space: normal;
      overflow: visible;
      text-overflow: unset;
      text-wrap: balance;
    }

    .hero__lead {
      align-items: flex-start;
      width: 100%;
      max-width: none;
    }

    .hero__eyebrow {
      white-space: normal;
      text-wrap: balance;
      line-height: 1.35;
    }
  }

  @media (max-height: 800px) and (min-width: 768px) {
    .hero {
      min-height: 0;
      gap: 24px;
      padding-bottom: 16px;
    }
  }

  @media (max-width: 767px) {
    .hero {
      min-height: 0;
      padding-bottom: 32px;
    }

    .hero__inner {
      align-items: stretch;
      text-align: left;
      width: min(100% - var(--margin) * 2, var(--hero-copy-max));
      flex: 0 1 auto;
      justify-content: flex-start;
    }

    .hero__title {
      margin-inline: 0;
      font-size: clamp(1.75rem, 8.5vw, 2.5rem);
    }

    .hero__lead {
      margin-inline: 0;
      font-size: clamp(0.9375rem, 3.8vw, 1.125rem);
      line-height: 1.45;
    }

    .hero__actions {
      flex-direction: column;
      align-items: stretch;
      margin-bottom: 28px;
    }

    .hero__actions :global(.btn-figma-primary),
    .hero__actions :global(.btn-figma-secondary) {
      width: 100%;
    }

    .hero__carousel {
      width: 100%;
      margin-left: 0;
      margin-right: 0;
    }

    .hero__viewport {
      margin-inline: 0;
      width: 100%;
      height: auto;
      aspect-ratio: 940 / 400;
      max-height: 52vw;
      border-radius: 0;
      overflow: hidden;
    }

    .hero__slide {
      border-radius: calc(28px * var(--hero-slide-scale, 1));
    }

    .hero__slide.is-active {
      opacity: 1;
      visibility: visible;
      width: calc(100% - 24px);
      height: 100%;
      aspect-ratio: auto;
      transform: translate(-50%, -50%);
    }

    .hero__slide.is-prev,
    .hero__slide.is-next,
    .hero__slide.is-far-prev,
    .hero__slide.is-far-next {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__slide {
      transition: none;
    }
  }
</style>
