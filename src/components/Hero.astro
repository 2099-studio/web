---
import type { Locale } from '../i18n';
import { getContent } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getContent(locale);

const titleLines = t.hero.title.split('\n').map((line) => line.trim()).filter(Boolean);
const leadLines = [t.hero.lead, t.hero.leadSecondary].filter(
  (line): line is string => Boolean(line?.trim()),
);
---

<section class="hero" id="hero" aria-labelledby="hero-title" data-hero>
  <div class="hero__inner container">
    <p class="hero__eyebrow" data-hero-content>{t.hero.eyebrow}</p>

    <div class="hero__copy" data-hero-title>
      <h1 class="hero__title" id="hero-title">
        {
          titleLines.map((line) => (
            <span class="hero__title-line">{line}</span>
          ))
        }
      </h1>
      <p class="hero__lead" data-hero-content>
        {leadLines.map((line) => (
          <span class="hero__lead-line">{line}</span>
        ))}
      </p>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100svh;
    padding-top: var(--header-height);
    padding-bottom: 48px;
    box-sizing: border-box;
    background: transparent;
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    width: min(100% - var(--margin) * 2, 920px);
    margin-inline: auto;
    gap: 0;
  }

  .hero__eyebrow {
    margin: 0 0 28px;
    padding: 0;
    font-family: var(--font-body);
    font-size: clamp(12px, 1.1vw, 14px);
    font-weight: 600;
    letter-spacing: 0.12em;
    line-height: 1.2;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .hero__copy {
    width: 100%;
  }

  .hero__title {
    margin: 0 auto 36px;
    width: fit-content;
    max-width: 100%;
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 6.2vw, 72px);
    font-weight: 700;
    line-height: 1.02;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
  }

  .hero__title-line {
    display: block;
  }

  .hero__lead {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    margin: 0 auto;
    max-width: 42rem;
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    font-weight: 400;
    line-height: 1.55;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
  }

  .hero__lead-line {
    display: block;
  }

  @media (max-width: 767px) {
    .hero {
      min-height: 100svh;
      padding-bottom: 40px;
    }

    .hero__eyebrow {
      margin-bottom: 20px;
      letter-spacing: 0.1em;
    }

    .hero__title {
      margin-bottom: 24px;
      font-size: clamp(2rem, 9vw, 2.75rem);
      line-height: 1.08;
    }

    .hero__lead {
      font-size: clamp(0.9375rem, 3.8vw, 1.0625rem);
      line-height: 1.5;
    }

    .hero__title-line,
    .hero__lead-line {
      text-wrap: balance;
    }
  }

  @media (max-height: 700px) and (min-width: 768px) {
    .hero__eyebrow {
      margin-bottom: 18px;
    }

    .hero__title {
      margin-bottom: 22px;
      font-size: clamp(2.25rem, 5vw, 3.25rem);
    }
  }
</style>
