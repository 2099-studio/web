---
import type { Locale } from '../i18n';
import { getContent } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getContent(locale);
const baseUrl = import.meta.env.BASE_URL;
---

<section class="hero" id="hero" aria-labelledby="hero-title">
  <div class="hero__content container">
    <p class="hero__eyebrow" data-hero-content>{t.hero.eyebrow}</p>

    <div class="hero__copy" data-hero-title>
      <h1 class="hero__title" id="hero-title">
        {t.hero.title} {t.hero.titleHighlight}.
      </h1>
      <p class="hero__lead" data-hero-content>{t.hero.lead}</p>
    </div>

    <div class="hero__actions" data-hero-content>
      <a class="btn-figma-primary" href="#works">{t.hero.ctaWorks}</a>
      <a class="btn-figma-secondary" href="#contact">{t.hero.ctaContact}</a>
    </div>
  </div>

  <div class="hero__graphic-wrap">
    <div class="hero__graphic" aria-hidden="true">
      <img
        class="hero__graphic-img"
        src={`${baseUrl}assets/brand/hero-2099.svg`}
        alt=""
        width="1480"
        height="506"
        decoding="async"
        fetchpriority="high"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--color-bg);
    overflow: hidden;
    padding-top: var(--header-height);
  }

  .hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: var(--hero-copy-max);
    padding-top: var(--hero-padding-top);
    padding-bottom: clamp(24px, 2.222vw, 43px);
  }

  .hero__eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-hero-eyebrow);
    margin-bottom: var(--hero-eyebrow-offset);
    width: 100%;
  }

  .hero__copy {
    width: 100%;
    margin-bottom: clamp(24px, 2.222vw, 43px);
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    margin-bottom: clamp(16px, 1.667vw, 32px);
    text-wrap: balance;
  }

  .hero__lead {
    font-family: var(--font-body);
    font-size: var(--text-hero-lead);
    font-weight: 400;
    line-height: 1.7;
    color: var(--color-text-secondary);
    text-wrap: pretty;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: clamp(12px, 1.111vw, 16px);
  }

  .hero__graphic-wrap {
    position: relative;
    z-index: 1;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    overflow: hidden;
    line-height: 0;
    pointer-events: none;
    margin-top: clamp(8px, 1.667vw, 24px);
  }

  .hero__graphic {
    width: var(--hero-graphic-width);
    max-width: none;
    margin-inline: auto;
  }

  .hero__graphic-img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
    object-position: center bottom;
  }

  @media (max-width: 767px) {
    .hero__content {
      align-items: stretch;
      text-align: left;
      max-width: none;
    }

    .hero__actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
