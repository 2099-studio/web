---
import type { Locale } from '../i18n';
import { getContent, localePath } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getContent(locale);
const { works: w } = t;
const homeHref = localePath(locale);
const badge = w.eyebrow.replace(/^\d+\s—\s/, '');
---

<section class="works figma-section" id="works" data-works data-section-hold aria-labelledby="works-title">
  <div class="works__sticky" data-section-hold-pin>
    <div class="works__fit">
      <div class="works__wrap container">
        <header class="figma-section__head" data-reveal>
          <span class="figma-badge">{badge}</span>
          <h2 class="figma-section__title" id="works-title" data-text-reveal>
            {w.title}
            {w.titleHighlight ? (
              <>
                {' '}
                <span style="color: var(--color-primary)">{w.titleHighlight}</span>.
              </>
            ) : null}
          </h2>
          {w.lead ? <p class="figma-section__subtitle" data-text-reveal>{w.lead}</p> : null}
        </header>

        <div class="works__filters" data-reveal>
          <div class="works__filter-group">
            <span class="works__filter-label">{w.filterIndustry}</span>
            <div class="works__filter-btns">
              {w.industryFilters.map((filter, i) => (
                <button type="button" class={`works__filter-btn${i === 0 ? ' is-active' : ''}`} data-works-filter-industry={filter.id}>{filter.label}</button>
              ))}
            </div>
          </div>
          <div class="works__filter-group">
            <span class="works__filter-label">{w.filterService}</span>
            <div class="works__filter-btns">
              {w.serviceFilters.map((filter, i) => (
                <button type="button" class={`works__filter-btn${i === 0 ? ' is-active' : ''}`} data-works-filter-service={filter.id}>{filter.label}</button>
              ))}
            </div>
          </div>
        </div>

        <div class="works__grid">
          {
            w.items.map((work) => {
              const href = work.live ? homeHref : undefined;
              const Tag = href ? 'a' : 'article';
              const props = href ? { href } : { tabindex: 0 as const };
              const primaryIndustry = work.industries[0];
              const primaryService = work.services[0];
              const metaParts = [
                primaryIndustry ? w.industryLabels[primaryIndustry] : null,
                primaryService ? w.serviceLabels[primaryService] : null,
              ].filter(Boolean);
              return (
                <Tag class="work-card" data-work-card data-work-item data-industries={work.industries.join(',')} data-services={work.services.join(',')} {...props}>
                  <div class="work-card__visual">
                    <span class="work-card__year">{work.year}</span>
                  </div>
                  <div class="work-card__body">
                    <h3 class="work-card__title">{work.title}</h3>
                    <p class="work-card__client">{metaParts.join(' · ') || work.client}</p>
                    {primaryIndustry ? (
                      <div class="work-card__tags">
                        <span>{w.industryLabels[primaryIndustry]}</span>
                      </div>
                    ) : null}
                  </div>
                </Tag>
              );
            })
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .works.figma-section {
    padding-block: 0;
  }

  .works__sticky {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    box-sizing: border-box;
    overflow: hidden;
  }

  .works__fit {
    width: 100%;
    padding-block: var(--section-padding-y);
    box-sizing: border-box;
  }

  /* Figma 663:2086 — 1280×180 filter panel */
  .works__filters {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-bottom: 48px;
    padding: 24px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 16px;
  }

  .works__filter-group {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .works__filter-label {
    display: block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
  }

  .works__filter-btns {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .works__filter-btn {
    padding: 8px 16px;
    font-size: 11px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    color: var(--color-text-secondary);
    background: transparent;
    cursor: pointer;
    transition:
      color 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease;
  }

  .works__filter-btn.is-active {
    color: var(--color-text-primary);
    background: transparent;
    border-color: var(--color-primary);
  }

  .works__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
  }

  /* Figma Work Card 411×340 */
  .work-card {
    display: flex;
    flex-direction: column;
    height: 340px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    color: inherit;
    text-decoration: none;
    transition: border-color 0.2s;
  }

  .work-card:hover {
    border-color: color-mix(in srgb, var(--color-primary) 40%, var(--color-border));
  }

  .work-card__visual {
    position: relative;
    flex: 1 1 auto;
    min-height: 0;
    background: #101725;
  }

  .work-card__year {
    position: absolute;
    top: 24px;
    left: 24px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    color: var(--color-text-tertiary);
  }

  .work-card__body {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 0 0 auto;
    padding: 24px;
    background: var(--color-surface);
  }

  .work-card__title {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .work-card__client {
    margin: 0;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 400;
    color: var(--color-text-secondary);
  }

  .work-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 8px;
  }

  .work-card__tags span {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    padding: 4px 12px;
    border: 1px solid var(--color-primary);
    border-radius: var(--radius-full);
    color: var(--color-primary);
    background: transparent;
  }

  @media (max-width: 900px) {
    .works__sticky {
      min-height: 0;
      overflow: visible;
    }

    .works__grid {
      grid-template-columns: 1fr;
    }

    .work-card {
      height: auto;
      min-height: 340px;
    }

    .work-card__visual {
      min-height: 200px;
    }
  }

  @media (min-width: 901px) and (max-width: 1100px) {
    .works__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
