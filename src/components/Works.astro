---
import type { Locale } from '../i18n';
import { getContent, localePath } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getContent(locale);
const { works: w } = t;
const homeHref = localePath(locale);
---

<section class="works figma-section" id="works" data-works aria-labelledby="works-title">
  <div class="works__wrap container">
    <header class="figma-section__head">
      <span class="figma-badge">{w.eyebrow.replace(/^\d+\s—\s/, '')}</span>
      <h2 class="figma-section__title" id="works-title">
        {w.title} <span style="color: var(--color-primary)">{w.titleHighlight}</span>.
      </h2>
      <p class="figma-section__subtitle">{w.lead}</p>
    </header>

    <div class="works__filters">
      <div class="works__filter-group">
        <span class="works__filter-label">{w.filterIndustry}</span>
        <div class="works__filter-btns">
          {w.industryFilters.map((filter, i) => (
            <button type="button" class={`works__filter-btn${i === 0 ? ' is-active' : ''}`} data-works-filter-industry={filter.id}>{filter.label}</button>
          ))}
        </div>
      </div>
      <div class="works__filter-group">
        <span class="works__filter-label">{w.filterService}</span>
        <div class="works__filter-btns">
          {w.serviceFilters.map((filter, i) => (
            <button type="button" class={`works__filter-btn${i === 0 ? ' is-active' : ''}`} data-works-filter-service={filter.id}>{filter.label}</button>
          ))}
        </div>
      </div>
    </div>

    <div class="works__grid">
      {
        w.items.map((work) => {
          const href = work.live ? homeHref : undefined;
          const Tag = href ? 'a' : 'article';
          const props = href ? { href } : { tabindex: 0 as const };
          return (
            <Tag class="work-card" data-work-card data-work-item data-industries={work.industries.join(',')} data-services={work.services.join(',')} {...props}>
              <div class="work-card__visual"><span class="work-card__year">{work.year}</span></div>
              <div class="work-card__body">
                <h3 class="work-card__title">{work.title}</h3>
                <p class="work-card__client">{work.client}</p>
                <p class="work-card__desc">{work.description}</p>
                <div class="work-card__tags">
                  {work.industries.map((ind) => <span>{w.industryLabels[ind]}</span>)}
                  {work.services.map((svc) => <span class="is-service">{w.serviceLabels[svc]}</span>)}
                </div>
              </div>
            </Tag>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .works__filters {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin-bottom: 48px;
    padding: 24px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
  }

  .works__filter-label {
    display: block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: 12px;
  }

  .works__filter-btns {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .works__filter-btn {
    padding: 8px 16px;
    font-size: 11px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    color: var(--color-text-secondary);
    background: var(--color-bg);
  }

  .works__filter-btn.is-active {
    color: var(--color-on-accent);
    background: var(--color-primary);
    border-color: var(--color-primary);
  }

  .works__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }

  .work-card {
    display: flex;
    flex-direction: column;
    min-height: 360px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    color: inherit;
    text-decoration: none;
    transition: border-color 0.2s;
  }

  .work-card:hover {
    border-color: color-mix(in srgb, var(--color-primary) 40%, var(--color-border));
  }

  .work-card__visual {
    height: 200px;
    background: linear-gradient(135deg, var(--color-elevated), var(--color-bg-muted));
    position: relative;
  }

  .work-card__year {
    position: absolute;
    top: 16px;
    left: 16px;
    font-size: 11px;
    color: var(--color-text-tertiary);
  }

  .work-card__body {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  .work-card__title {
    font-family: var(--font-display);
    font-size: var(--text-card-title);
    font-weight: 600;
  }

  .work-card__client {
    font-size: 11px;
    color: var(--color-text-tertiary);
  }

  .work-card__desc {
    font-size: 16px;
    line-height: 1.5;
    color: var(--color-text-secondary);
    margin-top: 8px;
  }

  .work-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: auto;
    padding-top: 16px;
  }

  .work-card__tags span {
    font-size: 10px;
    padding: 4px 10px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    color: var(--color-text-secondary);
  }

  .work-card__tags .is-service {
    color: var(--color-primary);
    border-color: color-mix(in srgb, var(--color-primary) 30%, var(--color-border));
  }

  @media (max-width: 768px) {
    .works__filters,
    .works__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
