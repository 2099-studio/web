---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<span class:list={['logo', className]}>
  <img
    class="logo__img logo__img--dark"
    src={`${baseUrl}assets/brand/logo-header.svg`}
    alt="2099.studio"
    width="73"
    height="42"
    decoding="async"
  />
  <img
    class="logo__img logo__img--light"
    src={`${baseUrl}assets/brand/logo-header.svg`}
    alt=""
    width="73"
    height="42"
    decoding="async"
    aria-hidden="true"
  />
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    line-height: 0;
    flex-shrink: 0;
  }

  .logo__img {
    display: block;
    width: 73px;
    height: 42px;
    object-fit: contain;
  }

  .logo__img--light {
    display: none;
  }

  :global([data-theme='light']) .logo__img--dark {
    display: none;
  }

  :global([data-theme='light']) .logo__img--light {
    display: block;
    filter: invert(1);
  }
</style>
