---
/**
 * Aceternity shooting-stars + stars-background — vanilla port for Astro.
 * @see https://ui.aceternity.com/components/shooting-stars-and-stars-background
 */
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div
  class:list={['stars-field', className]}
  data-stars-field
  data-star-color-dark="#2b5fff"
  data-star-color-light="#09090b"
  data-trail-color-dark="#5c85ff"
  data-trail-color-light="#525252"
  aria-hidden="true"
>
  <canvas class="stars-field__canvas" data-stars-bg></canvas>
  <svg class="stars-field__shooting" data-shooting-stars xmlns="http://www.w3.org/2000/svg">
    <defs>
      <linearGradient id="site-shooting-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" data-shooting-trail-stop stop-color="#5c85ff" stop-opacity="0" />
        <stop offset="100%" data-shooting-star-stop stop-color="#2b5fff" stop-opacity="1" />
      </linearGradient>
    </defs>
  </svg>
</div>

<style>
  .stars-field {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .stars-field__canvas,
  .stars-field__shooting {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .stars-field__shooting {
    overflow: visible;
  }

  @media (prefers-reduced-motion: reduce) {
    .stars-field__shooting {
      display: none;
    }
  }
</style>
