---
import type { Locale } from '../i18n';
import { getContent } from '../i18n';
import '../styles/contact.css';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getContent(locale);
const { contact: c, site } = t;
const { contact } = site;
const baseUrl = import.meta.env.BASE_URL;
---

<section class="contact figma-section" id="contact" data-section-hold aria-labelledby="contact-title">
  <div class="contact__sticky" data-section-hold-pin>
    <div class="contact__fit">
      <div class="contact__wrap container">
        <header class="contact__head" data-reveal>
          <span class="figma-badge">{c.title}</span>
          <h2 class="contact__title" id="contact-title" data-text-reveal>{c.lead}</h2>
        </header>

        <div class="contact__card" data-reveal>
          <form class="contact__form" data-contact-form>
            <p class="contact__intro">
              {c.formIntro}{' '}
              <a class="contact__intro-email" href={`mailto:${contact.email}`}>{c.formIntroEmail}</a>
            </p>

            <div class="contact__field">
              <label for="contact-name">{c.name}</label>
              <input type="text" id="contact-name" name="name" required autocomplete="name" placeholder={c.namePlaceholder} />
            </div>
            <div class="contact__field">
              <label for="contact-email">{c.email}</label>
              <input type="email" id="contact-email" name="email" required autocomplete="email" placeholder={c.emailPlaceholder} />
            </div>
            <div class="contact__field">
              <label for="contact-budget">{c.budget}</label>
              <select id="contact-budget" name="budget" required>
                <option value="" disabled selected>{c.selectPlaceholder}</option>
                {c.budgetOptions.map((option) => <option value={option}>{option}</option>)}
              </select>
            </div>
            <div class="contact__field contact__field--message">
              <label for="contact-message">{c.message}</label>
              <textarea id="contact-message" name="message" rows="3" required placeholder={c.messagePlaceholder}></textarea>
            </div>
            <button class="contact__submit" type="submit">{c.submit}</button>
            <p class="contact__success" data-contact-success hidden>{c.success}</p>
          </form>

          <div class="contact__media" aria-hidden="true">
            <img
              src={`${baseUrl}assets/brand/contact-abstract.png`}
              alt=""
              width="551"
              height="336"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
