---
import type { Locale } from '../i18n';
import { getContent } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getContent(locale);
const { contact: c, site } = t;
const { contact } = site;

const socialLinks = [
  { label: 'WhatsApp', href: contact.whatsapp },
  { label: 'LinkedIn', href: contact.linkedin },
  { label: 'Instagram', href: contact.instagram },
];
---

<section class="contact figma-section" id="contact" aria-labelledby="contact-title">
  <div class="contact__wrap container">
    <header class="figma-section__head">
      <span class="figma-badge">{c.eyebrow.replace(/^\d+\s—\s/, '')}</span>
      <h2 class="figma-section__title" id="contact-title">
        {c.title} <span style="color: var(--color-primary)">{c.titleHighlight}</span>{c.titleAfter}
      </h2>
      <p class="figma-section__subtitle">{c.lead}</p>
    </header>

    <div class="contact__layout">
      <form class="contact__form" data-contact-form>
        <div class="contact__field">
          <label for="contact-name">{c.name}</label>
          <input type="text" id="contact-name" name="name" required autocomplete="name" placeholder={c.namePlaceholder} />
        </div>
        <div class="contact__field">
          <label for="contact-email">{c.email}</label>
          <input type="email" id="contact-email" name="email" required autocomplete="email" placeholder={c.emailPlaceholder} />
        </div>
        <div class="contact__field">
          <label for="contact-type">{c.projectType}</label>
          <select id="contact-type" name="type" required>
            <option value="" disabled selected>{c.selectPlaceholder}</option>
            {c.projectTypes.map((type) => <option value={type}>{type}</option>)}
          </select>
        </div>
        <div class="contact__field">
          <label for="contact-message">{c.message} <span class="contact__opt">{c.messageOptional}</span></label>
          <textarea id="contact-message" name="message" rows="4" placeholder={c.messagePlaceholder}></textarea>
        </div>
        <button class="btn-figma-primary" type="submit">{c.submit}</button>
      </form>

      <aside class="contact__aside">
        <div>
          <p class="contact__label">{c.directEmail}</p>
          <a class="contact__email" href={`mailto:${contact.email}`}>{contact.email}</a>
        </div>
        <div>
          <p class="contact__label">{c.social}</p>
          <ul class="contact__social">
            {socialLinks.map((link) => (
              <li><a href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <p class="contact__label">{c.location}</p>
          <p class="contact__text">{contact.location}</p>
          <p class="contact__text is-muted">{contact.timezone}</p>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .contact__layout {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--gap-layout);
    align-items: start;
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 32px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .contact__field label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .contact__opt {
    text-transform: none;
    font-weight: 400;
    color: var(--color-text-tertiary);
  }

  .contact__field input,
  .contact__field select,
  .contact__field textarea {
    font-family: var(--font-body);
    font-size: 16px;
    padding: 12px 16px;
    color: var(--color-text-primary);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  .contact__field input:focus,
  .contact__field select:focus,
  .contact__field textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-accent-blue-glow);
  }

  .contact__form .btn-figma-primary {
    align-self: flex-start;
    margin-top: 8px;
  }

  .contact__aside {
    display: flex;
    flex-direction: column;
    gap: 40px;
    padding-top: 8px;
  }

  .contact__label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: 12px;
  }

  .contact__email {
    font-family: var(--font-display);
    font-size: var(--text-footer-email);
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-text-primary);
  }

  .contact__email:hover {
    color: var(--color-primary);
  }

  .contact__social {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .contact__social a {
    font-size: 16px;
    color: var(--color-text-secondary);
  }

  .contact__social a:hover {
    color: var(--color-primary);
  }

  .contact__text {
    font-size: 16px;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .contact__text.is-muted {
    font-size: 13px;
    color: var(--color-text-tertiary);
    margin-top: 4px;
  }

  @media (max-width: 768px) {
    .contact__layout {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
