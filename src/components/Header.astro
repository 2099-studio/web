---
import type { Locale } from '../i18n';
import { getContent, localePath } from '../i18n';
import Logo from './Logo.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getContent(locale);
const homePath = localePath(locale, '', import.meta.env.BASE_URL);

const navLinks = [
  { href: '#services', label: t.nav.services },
  { href: '#works', label: t.nav.works },
  { href: '#methodology', label: t.nav.studio },
];
---

<header class="header">
  <div class="header__inner container">
    <a class="header__logo" href={homePath} aria-label={t.nav.home}>
      <Logo height={32} />
    </a>

    <nav class="header__nav" aria-label={locale === 'es' ? 'Principal' : 'Main'}>
      <ul class="header__nav-list">
        {
          navLinks.map((link) => (
            <li>
              <a class="header__nav-link" href={link.href} data-magnetic>
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="header__actions">
      <button
        class="header__locale-toggle"
        type="button"
        data-locale-toggle
        aria-label={locale === 'es' ? t.locale.switchToEn : t.locale.switchToEs}
        title={locale === 'es' ? t.locale.switchToEn : t.locale.switchToEs}
      >
        <span class="header__locale-option header__locale-option--es">{t.locale.labelEs}</span>
        <span class="header__locale-option header__locale-option--en">{t.locale.labelEn}</span>
      </button>

      <button
        class="header__theme-toggle"
        type="button"
        data-theme-toggle
        aria-label={t.theme.ariaLight}
        aria-pressed="false"
        title={t.theme.titleLight}
      >
        <span class="header__theme-option header__theme-option--light">
          <svg
            class="header__theme-icon"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
            ></path>
          </svg>
          <span class="header__theme-label">{t.theme.light}</span>
        </span>

        <span class="header__theme-option header__theme-option--dark">
          <svg
            class="header__theme-icon"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            aria-hidden="true"
          >
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
          <span class="header__theme-label">{t.theme.dark}</span>
        </span>
      </button>

      <a class="btn-primary header__cta" href="#contact" data-magnetic>{t.nav.contact}</a>
    </div>
  </div>
</header>

<style>
  .header {
    position: fixed;
    inset: 0 0 auto;
    z-index: 100;
    height: var(--header-height);
    border-bottom: 1px solid transparent;
    transition:
      border-color var(--dur-base) var(--ease-out),
      background-color var(--dur-base) var(--ease-out);
  }

  .header.is-scrolled {
    border-bottom-color: var(--color-border);
    background: color-mix(in srgb, var(--color-bg) 88%, transparent);
    backdrop-filter: blur(12px);
  }

  .header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 100%;
    gap: var(--space-4);
  }

  .header__logo {
    --logo-height: 32px;
    justify-self: start;
  }

  .header__nav {
    justify-self: center;
  }

  .header__nav-list {
    display: none;
    align-items: center;
    gap: var(--space-8);
    list-style: none;
  }

  .header__nav-link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-secondary);
    transition: color var(--dur-fast) var(--ease-out);
  }

  .header__nav-link:hover,
  .header__nav-link:focus-visible {
    color: var(--color-text-primary);
  }

  .header__actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: var(--space-2);
    justify-self: end;
  }

  .header__locale-toggle,
  .header__theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 40px;
    padding: 0 var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    color: var(--color-text-secondary);
    background: transparent;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.06em;
    transition:
      border-color var(--dur-fast) var(--ease-out),
      color var(--dur-fast) var(--ease-out);
  }

  .header__locale-toggle:hover,
  .header__theme-toggle:hover {
    border-color: var(--color-text-tertiary);
    color: var(--color-text-primary);
  }

  .header__locale-toggle:focus-visible,
  .header__theme-toggle:focus-visible {
    outline: 2px solid var(--color-accent-orange);
    outline-offset: 3px;
  }

  .header__locale-option,
  .header__theme-option {
    display: none;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 500;
  }

  :global(html[lang='es']) .header__locale-option--en {
    display: inline-flex;
  }

  :global(html[lang='en']) .header__locale-option--es {
    display: inline-flex;
  }

  :global(:root) .header__theme-option--light,
  :global([data-theme='dark']) .header__theme-option--light {
    display: inline-flex;
  }

  :global([data-theme='light']) .header__theme-option--light {
    display: none;
  }

  :global([data-theme='light']) .header__theme-option--dark {
    display: inline-flex;
  }

  .header__theme-icon {
    flex-shrink: 0;
  }

  .header__cta {
    height: 40px;
    padding-inline: var(--space-6);
    white-space: nowrap;
  }

  @media (min-width: 768px) {
    .header__nav-list {
      display: flex;
    }

    .header__actions {
      gap: var(--space-3);
    }
  }

  @media (max-width: 480px) {
    .header__theme-label {
      display: none;
    }

    .header__locale-toggle,
    .header__theme-toggle {
      width: 40px;
      padding: 0;
    }

    .header__cta {
      padding-inline: var(--space-4);
      font-size: var(--text-xs);
    }
  }
</style>

<script>
  const header = document.querySelector('.header');
  if (header) {
    const onScroll = () => {
      header.classList.toggle('is-scrolled', window.scrollY > 24);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
