---
import type { Locale } from '../i18n';
import { getContent, localePath } from '../i18n';
import Logo from './Logo.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getContent(locale);
const homePath = localePath(locale, '', import.meta.env.BASE_URL);

const navLinks = [
  { href: '#services', label: t.nav.services },
  { href: '#works', label: t.nav.works },
  { href: '#methodology', label: t.nav.studio },
];
---

<header class="header">
  <div class="header__inner container">
    <div class="header__zone header__zone--logo">
      <a class="header__logo-link" href={homePath} aria-label={t.nav.home}>
        <Logo />
      </a>
    </div>

    <button class="header__toggle" type="button" data-nav-toggle aria-expanded="false" aria-controls="mobile-nav" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>

    <nav class="header__zone header__zone--nav" aria-label={locale === 'es' ? 'Principal' : 'Main'}>
      <ul class="header__nav-list">
        {navLinks.map((link) => (
          <li><a class="header__nav-link" href={link.href} data-nav-link>{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="header__zone header__zone--actions">
      <button class="header__pill header__pill--locale" type="button" data-locale-toggle aria-label={locale === 'es' ? t.locale.switchToEn : t.locale.switchToEs}>
        <span class="header__locale-option header__locale-option--es">{t.locale.labelEs}</span>
        <span class="header__locale-option header__locale-option--en">{t.locale.labelEn}</span>
      </button>
      <button class="header__pill header__pill--theme" type="button" data-theme-toggle aria-label={t.theme.ariaLight}>
        <svg class="header__theme-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
        </svg>
        <span class="header__theme-option header__theme-option--light">{t.theme.light}</span>
        <span class="header__theme-option header__theme-option--dark">{t.theme.dark}</span>
      </button>
      <a class="btn-figma-primary header__cta" href="#contact">{t.nav.contact}</a>
    </div>
  </div>

  <div class="header__mobile" id="mobile-nav" data-nav-panel hidden>
    <ul class="header__mobile-list">
      {navLinks.map((link) => (
        <li><a class="header__mobile-link" href={link.href} data-nav-link>{link.label}</a></li>
      ))}
    </ul>
    <div class="header__mobile-tools" aria-label={locale === 'es' ? 'Preferencias' : 'Preferences'}>
      <button class="header__pill header__pill--locale" type="button" data-locale-toggle aria-label={locale === 'es' ? t.locale.switchToEn : t.locale.switchToEs}>
        <span class="header__locale-option header__locale-option--es">{t.locale.labelEs}</span>
        <span class="header__locale-option header__locale-option--en">{t.locale.labelEn}</span>
      </button>
      <button class="header__pill header__pill--theme" type="button" data-theme-toggle aria-label={t.theme.ariaLight}>
        <svg class="header__theme-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
        </svg>
        <span class="header__theme-option header__theme-option--light">{t.theme.light}</span>
        <span class="header__theme-option header__theme-option--dark">{t.theme.dark}</span>
      </button>
    </div>
    <a class="btn-figma-primary" href="#contact" data-nav-link>{t.nav.contact}</a>
  </div>
</header>

<style>
  .header {
    position: fixed;
    inset: 0 0 auto;
    z-index: 100;
    background: var(--color-bg);
    border-bottom: 1px solid transparent;
  }

  .header.is-scrolled {
    border-bottom-color: var(--color-border);
  }

  .header__inner {
    display: flex;
    align-items: center;
    gap: 16px;
    height: 72px;
  }

  .header__zone--logo {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    align-items: center;
  }

  .header__logo-link {
    display: inline-flex;
    align-items: center;
  }

  .header__zone--nav {
    flex: 0 0 auto;
  }

  .header__zone--actions {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 8px;
  }

  .header__toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    margin-left: 0;
    padding: 10px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-surface);
    flex-shrink: 0;
  }

  .header__toggle span {
    display: block;
    height: 2px;
    background: var(--color-text-primary);
    border-radius: 1px;
    transition: transform 0.2s, opacity 0.2s;
  }

  .header.is-open .header__toggle span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .header.is-open .header__toggle span:nth-child(2) { opacity: 0; }
  .header.is-open .header__toggle span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .header__nav-list {
    display: flex;
    align-items: center;
    gap: 32px;
    list-style: none;
  }

  .header__nav-link {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    color: var(--color-text-secondary);
    white-space: nowrap;
    transition: color 0.15s;
  }

  .header__nav-link:hover {
    color: var(--color-text-primary);
  }

  .header__pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: 40px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    line-height: 1;
    color: var(--color-text-secondary);
    background: transparent;
  }

  .header__pill--locale {
    width: 56px;
    padding: 0;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.06em;
  }

  .header__pill--theme {
    width: auto;
    min-width: 88px;
    padding: 0 14px;
  }

  .header__theme-icon {
    display: block;
    flex-shrink: 0;
    width: 16px;
    height: 16px;
  }

  .header__theme-option {
    line-height: 1;
  }

  .header__pill--theme :global(.btn-gooey__label) {
    gap: 8px;
  }

  .header__locale-option,
  .header__theme-option {
    display: none;
  }

  :global(html[lang='es']) .header__locale-option--en { display: inline; }
  :global(html[lang='en']) .header__locale-option--es { display: inline; }
  :global(:root) .header__theme-option--light,
  :global([data-theme='dark']) .header__theme-option--light { display: inline; }
  :global([data-theme='light']) .header__theme-option--light { display: none; }
  :global([data-theme='light']) .header__theme-option--dark { display: inline; }

  :global(.btn-figma-primary).header__cta {
    box-sizing: border-box;
    height: 40px;
    min-height: 40px;
    padding: 0 20px;
    font-size: 16px;
    font-weight: 500;
    line-height: 1;
  }

  .header__mobile :global(.btn-figma-primary) {
    height: 44px;
    min-height: 44px;
    padding: 0 20px;
    font-size: 16px;
  }

  .header__mobile {
    padding: 0 var(--margin) 24px;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .header__mobile[hidden] { display: none; }
  .header.is-open .header__mobile { display: block; }

  .header__mobile-list {
    list-style: none;
    padding: 16px 0;
  }

  .header__mobile-link {
    display: block;
    padding: 12px 0;
    font-size: 18px;
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .header__mobile-tools {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }

  .header__mobile-tools .header__pill {
    flex: 1 1 0;
    height: 44px;
    min-width: 0;
  }

  .header__mobile-tools .header__pill--locale {
    width: auto;
    max-width: 88px;
    flex: 0 0 auto;
  }

  @media (min-width: 1024px) {
    .header__toggle,
    .header__mobile {
      display: none !important;
    }

    .header__zone--nav {
      display: block;
    }

    .header__zone--actions {
      gap: 12px;
    }

    .header__mobile-tools {
      display: none;
    }
  }

  @media (max-width: 1023px) {
    .header__inner {
      gap: 10px;
    }

    .header__zone--logo {
      order: 1;
      flex: 1 1 auto;
    }

    .header__zone--actions {
      order: 2;
      flex: 0 0 auto;
    }

    .header__toggle {
      order: 3;
    }

    .header__zone--nav {
      display: none;
    }

    .header__cta {
      display: none;
    }

    .header__pill--theme {
      min-width: 0;
      padding: 0 12px;
    }

    .header__pill--locale {
      width: 48px;
    }
  }

  @media (max-width: 420px) {
    .header__zone--actions .header__theme-option {
      display: none !important;
    }

    .header__zone--actions .header__pill--theme {
      width: 40px;
      min-width: 40px;
      padding: 0;
    }
  }
</style>

<script>
  const header = document.querySelector('.header');
  const toggle = document.querySelector('[data-nav-toggle]');
  const panel = document.querySelector('[data-nav-panel]');

  window.addEventListener('scroll', () => {
    header?.classList.toggle('is-scrolled', window.scrollY > 8);
  }, { passive: true });

  toggle?.addEventListener('click', () => {
    const open = !header?.classList.contains('is-open');
    header?.classList.toggle('is-open', open);
    toggle.setAttribute('aria-expanded', String(open));
    panel?.toggleAttribute('hidden', !open);
  });

  document.querySelectorAll('[data-nav-link]').forEach((el) => {
    el.addEventListener('click', () => {
      header?.classList.remove('is-open');
      panel?.setAttribute('hidden', '');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
