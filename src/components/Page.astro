---
import type { Locale } from '../i18n';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from './Header.astro';
import Hero from './Hero.astro';
import Services from './Services.astro';
import Industries from './Industries.astro';
import Methodology from './Methodology.astro';
import Works from './Works.astro';
import Contact from './Contact.astro';
import Footer from './Footer.astro';
import { getContent } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getContent(locale);
---

<BaseLayout locale={locale} title={t.meta.title} description={t.meta.description}>
  <div class="site-shell">
    <Header locale={locale} />

    <main class="site-main">
      <Hero locale={locale} />
      <Services locale={locale} />
      <Industries locale={locale} />
      <Methodology locale={locale} />
      <Works locale={locale} />
      <Contact locale={locale} />
    </main>

    <Footer locale={locale} />
  </div>
</BaseLayout>
