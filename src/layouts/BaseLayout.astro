---
import type { Locale } from '../i18n';
import { localePath } from '../i18n';

interface Props {
  locale: Locale;
  title: string;
  description?: string;
}

const { locale, title, description } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const siteUrl = Astro.site?.href.replace(/\/$/, '') ?? 'https://2099.studio';
const esUrl = `${siteUrl}${localePath('es', '', baseUrl)}`;
const enUrl = `${siteUrl}${localePath('en', '', baseUrl)}`;
---

<!doctype html>
<html lang={locale} data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FFFFFF" />
    <meta name="base-url" content={baseUrl} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${baseUrl}favicon.png`} data-favicon />
    <link rel="icon" type="image/png" sizes="48x48" href={`${baseUrl}favicon-48.png`} data-favicon />
    <link rel="apple-touch-icon" sizes="180x180" href={`${baseUrl}apple-touch-icon.png`} />
    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={esUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Syne:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script is:inline define:vars={{ locale, baseUrl }}>
      (function () {
        const STORAGE_KEY = '2099-locale';
        const path = location.pathname;
        const base = baseUrl;
        const enPrefix = base === '/' ? '/en' : base.replace(/\/$/, '') + '/en';
        const onEn = path === enPrefix || path === enPrefix + '/' || path.startsWith(enPrefix + '/');
        const current = onEn ? 'en' : 'es';
        const hash = location.hash || '';
        const saved = localStorage.getItem(STORAGE_KEY);
        const isHome =
          path === base ||
          path === base + 'index.html' ||
          (base === '/' && (path === '/' || path === '/index.html'));

        if (saved === 'en' && current === 'es' && isHome) {
          location.replace((base === '/' ? '/en/' : base + 'en/') + hash);
          return;
        }
        if (saved === 'es' && current === 'en') {
          location.replace(base + hash);
          return;
        }
        if (!saved) {
          const lang = (navigator.language || '').toLowerCase();
          const prefersEs = lang.indexOf('es') === 0;
          const prefersEn = lang.indexOf('en') === 0;
          if (prefersEn && !prefersEs && current === 'es' && isHome) {
            localStorage.setItem(STORAGE_KEY, 'en');
            location.replace((base === '/' ? '/en/' : base + 'en/') + hash);
            return;
          }
          if (prefersEs && current === 'en') {
            localStorage.setItem(STORAGE_KEY, 'es');
            location.replace(base + hash);
            return;
          }
        }

        const savedTheme = localStorage.getItem('2099-theme');
        const theme = savedTheme === 'dark' || savedTheme === 'light' ? savedTheme : 'light';
        document.documentElement.setAttribute('data-theme', theme);
        const themeColor = theme === 'light' ? '#FFFFFF' : '#080808';
        document.querySelector('meta[name="theme-color"]')?.setAttribute('content', themeColor);
      })();
    </script>
  </head>
  <body>
    <slot />
    <script>
      import { initTheme } from '../scripts/theme';
      import { initMotion } from '../scripts/motion';
      import { initLocale } from '../scripts/locale';
      import { initFavicon } from '../scripts/favicon';

      initTheme();
      initLocale();
      initMotion();
      void initFavicon();
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  body.has-custom-cursor {
    cursor: none;
  }

  body.has-custom-cursor a,
  body.has-custom-cursor button {
    cursor: none;
  }

  .cursor-dot,
  .cursor-ring {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 10000;
    border-radius: var(--radius-full);
    transform: translate3d(-50%, -50%, 0);
    will-change: transform;
  }

  .cursor-dot {
    width: 6px;
    height: 6px;
    background: var(--color-primary);
  }

  .cursor-ring {
    width: 36px;
    height: 36px;
    border: 1px solid color-mix(in srgb, var(--color-text-primary) 35%, transparent);
    transition: width var(--dur-fast) var(--ease-out), height var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }

  .cursor-ring.is-hover {
    width: 52px;
    height: 52px;
    border-color: var(--color-primary);
  }

  @media (pointer: coarse) {
    body.has-custom-cursor {
      cursor: auto;
    }

    .cursor-dot,
    .cursor-ring {
      display: none;
    }
  }
</style>
