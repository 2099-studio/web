{
  "$description": "2099.studio Design Tokens v1.0 — DTCG format for Token Studio Pro",
  "core": {
    "font": {
      "family": {
        "display": {
          "$type": "fontFamily",
          "$value": "Clash Display",
          "$description": "H1, H2, heroes, section titles"
        },
        "body": {
          "$type": "fontFamily",
          "$value": "Satoshi",
          "$description": "Paragraphs, nav, labels, buttons"
        },
        "mono": {
          "$type": "fontFamily",
          "$value": "Space Mono",
          "$description": "Code, data, technical labels"
        },
        "logo-numerals": {
          "$type": "fontFamily",
          "$value": "Space Mono",
          "$description": "Logo 2099 — exclusive, do not use in headlines"
        },
        "logo-suffix": {
          "$type": "fontFamily",
          "$value": "Pixelity Sans",
          "$description": "Logo .studio — exclusive, do not use elsewhere"
        }
      },
      "weight": {
        "regular": { "$type": "fontWeight", "$value": 400 },
        "medium": { "$type": "fontWeight", "$value": 500 },
        "bold": { "$type": "fontWeight", "$value": 700 }
      },
      "size": {
        "xs": { "$type": "dimension", "$value": "11px", "$description": "Captions, small labels" },
        "sm": { "$type": "dimension", "$value": "13px", "$description": "UI labels, nav" },
        "md": { "$type": "dimension", "$value": "16px", "$description": "Body text base" },
        "lg": { "$type": "dimension", "$value": "20px", "$description": "Subtitles, intro text" },
        "xl": { "$type": "dimension", "$value": "32px", "$description": "H3, section headers" },
        "2xl": { "$type": "dimension", "$value": "48px", "$description": "H2" },
        "3xl": { "$type": "dimension", "$value": "72px", "$description": "H1" },
        "hero": { "$type": "dimension", "$value": "96px", "$description": "Hero display — use clamp(72px, 10vw, 120px) in CSS" }
      },
      "letter-spacing": {
        "display-tight": { "$type": "dimension", "$value": "-0.02em", "$description": "Large Clash Display headlines" }
      }
    },
    "space": {
      "1": { "$type": "dimension", "$value": "4px" },
      "2": { "$type": "dimension", "$value": "8px" },
      "3": { "$type": "dimension", "$value": "12px" },
      "4": { "$type": "dimension", "$value": "16px" },
      "6": { "$type": "dimension", "$value": "24px" },
      "8": { "$type": "dimension", "$value": "32px" },
      "12": { "$type": "dimension", "$value": "48px" },
      "16": { "$type": "dimension", "$value": "64px" },
      "24": { "$type": "dimension", "$value": "96px" },
      "32": { "$type": "dimension", "$value": "128px" }
    },
    "radius": {
      "sm": { "$type": "dimension", "$value": "4px" },
      "md": { "$type": "dimension", "$value": "8px" },
      "lg": { "$type": "dimension", "$value": "16px" },
      "xl": { "$type": "dimension", "$value": "24px" },
      "full": { "$type": "dimension", "$value": "9999px" }
    },
    "motion": {
      "ease-out": {
        "$type": "cubicBezier",
        "$value": [0, 0, 0.2, 1]
      },
      "ease-spring": {
        "$type": "cubicBezier",
        "$value": [0.34, 1.56, 0.64, 1]
      },
      "duration": {
        "fast": { "$type": "duration", "$value": "150ms" },
        "base": { "$type": "duration", "$value": "300ms" },
        "slow": { "$type": "duration", "$value": "600ms" },
        "page": { "$type": "duration", "$value": "900ms" },
        "text-reveal": { "$type": "duration", "$value": "800ms" },
        "pixel-disintegration": { "$type": "duration", "$value": "1200ms" },
        "hover-card": { "$type": "duration", "$value": "200ms" },
        "cursor-magnetic": { "$type": "duration", "$value": "100ms" },
        "fade-section": { "$type": "duration", "$value": "500ms" }
      }
    },
    "layout": {
      "max-width": { "$type": "dimension", "$value": "1280px" },
      "gutter": { "$type": "dimension", "$value": "24px" },
      "margin": { "$type": "dimension", "$value": "80px", "$description": "Use clamp(16px, 5vw, 80px) in CSS" },
      "cols": { "$type": "number", "$value": 12 }
    },
    "breakpoint": {
      "sm": { "$type": "dimension", "$value": "640px" },
      "md": { "$type": "dimension", "$value": "768px" },
      "lg": { "$type": "dimension", "$value": "1024px" },
      "xl": { "$type": "dimension", "$value": "1280px" }
    }
  },
  "theme-dark": {
    "color": {
      "bg": {
        "$type": "color",
        "$value": "#080808",
        "$description": "Void — main background"
      },
      "surface": {
        "$type": "color",
        "$value": "#111111",
        "$description": "Cards and panels"
      },
      "elevated": {
        "$type": "color",
        "$value": "#1E1E1E",
        "$description": "Hover states, dropdowns"
      },
      "border": {
        "$type": "color",
        "$value": "#2A2A2A",
        "$description": "Borders and dividers"
      },
      "text-primary": {
        "$type": "color",
        "$value": "#F2F2F0",
        "$description": "White — primary text"
      },
      "text-secondary": {
        "$type": "color",
        "$value": "#666663",
        "$description": "Muted — secondary text"
      },
      "text-tertiary": {
        "$type": "color",
        "$value": "#3A3A38",
        "$description": "Dim — placeholders"
      },
      "accent-orange": {
        "$type": "color",
        "$value": "#FF5C1A",
        "$description": "Studio Orange — CTAs, hero highlights"
      },
      "accent-orange-dark": {
        "$type": "color",
        "$value": "#CC3A00",
        "$description": "Orange hover state"
      },
      "accent-orange-glow": {
        "$type": "color",
        "$value": "rgba(255, 92, 26, 0.15)",
        "$description": "Orange glow effects"
      },
      "accent-blue": {
        "$type": "color",
        "$value": "#2B5FFF",
        "$description": "Studio Blue — links, tags, technical"
      },
      "accent-blue-dark": {
        "$type": "color",
        "$value": "#1A3FCC",
        "$description": "Blue hover state"
      },
      "accent-blue-glow": {
        "$type": "color",
        "$value": "rgba(43, 95, 255, 0.15)",
        "$description": "Blue glow effects"
      },
      "gradient-brand-start": {
        "$type": "color",
        "$value": "#FF5C1A"
      },
      "gradient-brand-end": {
        "$type": "color",
        "$value": "#2B5FFF"
      },
      "noise-opacity": {
        "$type": "number",
        "$value": 0.05
      }
    },
    "shadow": {
      "sm": {
        "$type": "shadow",
        "$value": {
          "offsetX": "0px",
          "offsetY": "1px",
          "blur": "3px",
          "color": "rgba(0, 0, 0, 0.5)"
        }
      },
      "md": {
        "$type": "shadow",
        "$value": {
          "offsetX": "0px",
          "offsetY": "4px",
          "blur": "16px",
          "color": "rgba(0, 0, 0, 0.6)"
        }
      },
      "lg": {
        "$type": "shadow",
        "$value": {
          "offsetX": "0px",
          "offsetY": "8px",
          "blur": "40px",
          "color": "rgba(0, 0, 0, 0.8)"
        }
      }
    }
  },
  "theme-light": {
    "color": {
      "bg": {
        "$type": "color",
        "$value": "#F5F4F0",
        "$description": "Paper — main background"
      },
      "surface": {
        "$type": "color",
        "$value": "#FFFFFF",
        "$description": "Cards and panels"
      },
      "elevated": {
        "$type": "color",
        "$value": "#EDECE8",
        "$description": "Hover states, dropdowns"
      },
      "border": {
        "$type": "color",
        "$value": "#DDDBD5",
        "$description": "Borders and dividers"
      },
      "text-primary": {
        "$type": "color",
        "$value": "#0A0A0A",
        "$description": "Ink — primary text"
      },
      "text-secondary": {
        "$type": "color",
        "$value": "#6B6965",
        "$description": "Stone — secondary text"
      },
      "text-tertiary": {
        "$type": "color",
        "$value": "#B5B3AD",
        "$description": "Dust — placeholders"
      },
      "accent-orange": {
        "$type": "color",
        "$value": "#D94400",
        "$description": "Orange Deep — AA contrast on light"
      },
      "accent-orange-dark": {
        "$type": "color",
        "$value": "#B33600",
        "$description": "Orange hover on light"
      },
      "accent-orange-glow": {
        "$type": "color",
        "$value": "rgba(217, 68, 0, 0.08)",
        "$description": "Orange tint on light"
      },
      "accent-blue": {
        "$type": "color",
        "$value": "#1A3FCC",
        "$description": "Blue Deep — AA contrast on light"
      },
      "accent-blue-dark": {
        "$type": "color",
        "$value": "#102B99",
        "$description": "Blue hover on light"
      },
      "accent-blue-glow": {
        "$type": "color",
        "$value": "rgba(26, 63, 204, 0.08)",
        "$description": "Blue tint on light"
      },
      "gradient-brand-start": {
        "$type": "color",
        "$value": "#D94400"
      },
      "gradient-brand-end": {
        "$type": "color",
        "$value": "#1A3FCC"
      },
      "noise-opacity": {
        "$type": "number",
        "$value": 0.03
      }
    },
    "shadow": {
      "sm": {
        "$type": "shadow",
        "$value": {
          "offsetX": "0px",
          "offsetY": "1px",
          "blur": "3px",
          "color": "rgba(0, 0, 0, 0.08)"
        }
      },
      "md": {
        "$type": "shadow",
        "$value": {
          "offsetX": "0px",
          "offsetY": "4px",
          "blur": "16px",
          "color": "rgba(0, 0, 0, 0.10)"
        }
      },
      "lg": {
        "$type": "shadow",
        "$value": {
          "offsetX": "0px",
          "offsetY": "8px",
          "blur": "40px",
          "color": "rgba(0, 0, 0, 0.14)"
        }
      }
    }
  },
  "$themes": [
    {
      "id": "dark",
      "name": "Dark",
      "selectedTokenSets": {
        "core": "enabled",
        "theme-dark": "enabled",
        "theme-light": "disabled"
      }
    },
    {
      "id": "light",
      "name": "Light",
      "selectedTokenSets": {
        "core": "enabled",
        "theme-dark": "disabled",
        "theme-light": "enabled"
      }
    }
  ]
}
